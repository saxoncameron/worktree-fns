# Hand off a worktree: remove it but keep its branch and commits in the repo.
#
# If a worktree name is given, use it; otherwise detect the current worktree
# by crawling upward for a .worktrees/ parent. Errors if the worktree has
# uncommitted changes.
gwh() {
  local currentDir repoRoot worktreeDir worktreeName

  repoRoot=$(_gw_repo_root_path) || return 1
  currentDir=${PWD:A}

  if (( $# )); then
    worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")
  else
    # Detect worktree from cwd by finding a .worktrees/ ancestor segment
    if [[ $currentDir == "$repoRoot/.worktrees/"* ]]; then
      worktreeName=${currentDir#"$repoRoot/.worktrees/"}
      worktreeName=${worktreeName%%/*}
      worktreeDir="$repoRoot/.worktrees/$worktreeName"
    else
      _gw_log error 'error: not inside a worktree; pass a worktree name'
      gwls >&2
      return 1
    fi
  fi

  [[ -n "$worktreeDir" && -d "$worktreeDir" ]] || {
    _gw_log error 'error: could not resolve worktree'
    gwls >&2
    return 1
  }

  # Check for uncommitted changes
  local statusOutput
  _gw_prune_clean_overlay_files "$repoRoot" "$worktreeDir" >/dev/null 2>&1
  statusOutput=$(git -C "$worktreeDir" status --porcelain 2>/dev/null)
  if [[ -n "$statusOutput" ]]; then
    _gw_log error 'error: worktree has uncommitted changes'
    print -r -- "$statusOutput"
    return 1
  fi

  local branchName
  branchName=$(git -C "$worktreeDir" symbolic-ref --quiet --short HEAD 2>/dev/null) || {
    _gw_log error 'error: worktree is in detached HEAD state'
    return 1
  }

  # If we're inside the worktree, cd back to repo root first
  local shouldCdBack=0
  [[ $currentDir == "$worktreeDir" || $currentDir == "$worktreeDir/"* ]] && shouldCdBack=1

  local removeOutput removeStatus
  removeOutput=$(git -C "$repoRoot" worktree remove -- "$worktreeDir" 2>&1)
  removeStatus=$?

  if (( removeStatus )); then
    _gw_log error 'error: failed to remove worktree'
    print -r -- "$removeOutput"
    return 1
  fi

  _gw_log success "Handed off %F{cyan}${branchName}%f; branch preserved and worktree removed"
  (( shouldCdBack )) && gwp
  return 0
}
