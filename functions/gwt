# Return to the root of the current checked-out worktree.
#
# This differs from "gwp":
# - "gwt" uses Git's current worktree top-level
# - "gwp" uses the nearest parent containing .worktrees
gwt() {
  local worktreeRoot
  worktreeRoot=$(git rev-parse --show-toplevel 2>/dev/null) || {
    _gw_log info 'No worktree root to return to.'
    return 0
  }
  _gw_log success "Returned to worktree root %F{yellow}${worktreeRoot:t}%f"
  builtin cd "$worktreeRoot"
}
