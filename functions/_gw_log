# Print a styled status line for interactive use.
#
# Defaults to a colored project prefix, with a plain fallback for tests or
# machine-friendly output via GW_LOG_STYLE=plain / NO_COLOR.
_gw_log() {
  local color label message
  label=$1
  shift
  message="$*"

  case "$label" in
    info)
      color='cyan'
      ;;
    success)
      color='green'
      ;;
    warn)
      color='yellow'
      ;;
    error)
      color='red'
      ;;
    step)
      color='blue'
      ;;
    list)
      color='magenta'
      ;;
    *)
      color='white'
      ;;
  esac

  if [[ ${GW_LOG_STYLE:-styled} == 'plain' || -n ${NO_COLOR:-} ]]; then
    print -r -- "🌱 [$label] $message"
    return 0
  fi

  print -P "%F{$color}🌱 [$label]%f $message"
}
