# Print a styled status line for interactive use.
#
# Defaults to a colored project prefix, with a plain fallback for tests or
# machine-friendly output via GW_LOG_STYLE=plain / NO_COLOR. Only error logs
# keep a bracketed label; other log kinds render as a plain project prefix.
_gw_log() {
  local color prefix label message
  label=$1
  shift
  message="$*"

  case "$label" in
    info)
      color='cyan'
      ;;
    success)
      color='green'
      ;;
    warn)
      color='yellow'
      ;;
    error)
      color='red'
      ;;
    step)
      color='blue'
      ;;
    list)
      color='magenta'
      ;;
    *)
      color='white'
      ;;
  esac

  prefix='🌱'
  [[ "$label" == 'error' ]] && prefix='🌱 [error]'

  if [[ ${GW_LOG_STYLE:-styled} == 'plain' || -n ${NO_COLOR:-} ]]; then
    print -r -- "$prefix $message"
    return 0
  fi

  print -P "%F{$color}${prefix}%f $message"
}
