# Merge a worktree's branch back into the repo root and clean up.
#
# Resolves the worktree from args or the current cwd, merges its branch into
# whatever the repo root has checked out, then removes the worktree via "gwd".
# If the merge produces conflicts the merge is aborted, a red error is
# printed, and "gwdiff" is shown so the user can see what was in flight.
gwm() {
  local currentDir gitCommonDir repoRoot worktreeDir worktreeName
  local branchName

  gitCommonDir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  repoRoot=${gitCommonDir:h}
  currentDir=${PWD:A}

  if (( $# )); then
    worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")
  else
    if [[ $currentDir == "$repoRoot/.worktrees/"* ]]; then
      worktreeName=${currentDir#"$repoRoot/.worktrees/"}
      worktreeName=${worktreeName%%/*}
      worktreeDir="$repoRoot/.worktrees/$worktreeName"
    else
      print -P "%F{red}error: not inside a worktree — pass a worktree name%f"
      gwls >&2
      return 1
    fi
  fi

  [[ -n "$worktreeDir" && -d "$worktreeDir" ]] || {
    print -P "%F{red}error: could not resolve worktree%f"
    gwls >&2
    return 1
  }

  branchName=$(git -C "$worktreeDir" symbolic-ref --quiet --short HEAD 2>/dev/null) || {
    print -P "%F{red}error: worktree is in detached HEAD state%f"
    return 1
  }

  local mergeOutput mergeStatus
  mergeOutput=$(git -C "$repoRoot" merge "$branchName" 2>&1)
  mergeStatus=$?

  if (( mergeStatus )); then
    git -C "$repoRoot" merge --abort 2>/dev/null
    print -P "%F{red}error: merge conflict — aborting%f"
    print -r -- "$mergeOutput"
    gwdiff "${worktreeDir:t}"
    return 1
  fi

  gwd "${worktreeDir:t}"
}
