# Merge a worktree's branch back into the repo root and clean up.
#
# Resolves the worktree from args or the current cwd, merges its branch into
# whatever the repo root has checked out, then removes the worktree via "gwr".
# If the merge produces conflicts the merge is aborted, a red error is
# printed, and "gwdiff" is shown so the user can see what was in flight.
gwm() {
  local currentDir repoRoot worktreeDir worktreeName
  local branchName

  repoRoot=$(_gw_find_repo_root) || return 1
  currentDir=${PWD:A}

  if (( $# )); then
    worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")
  else
    if [[ $currentDir == "$repoRoot/.worktrees/"* ]]; then
      worktreeName=${currentDir#"$repoRoot/.worktrees/"}
      worktreeName=${worktreeName%%/*}
      worktreeDir="$repoRoot/.worktrees/$worktreeName"
    else
      _gw_log error 'error: not inside a worktree; pass a worktree name'
      gwls >&2
      return 1
    fi
  fi

  [[ -n "$worktreeDir" && -d "$worktreeDir" ]] || {
    _gw_log error 'error: could not resolve worktree'
    gwls >&2
    return 1
  }

  branchName=$(git -C "$worktreeDir" symbolic-ref --quiet --short HEAD 2>/dev/null) || {
    _gw_log error 'error: worktree is in detached HEAD state'
    return 1
  }

  local targetBranch mergeOutput mergeStatus
  targetBranch=$(git -C "$repoRoot" symbolic-ref --quiet --short HEAD 2>/dev/null)

  _gw_log step "Merging %F{yellow}${branchName}%f into %F{green}${targetBranch}%f"

  mergeOutput=$(git -C "$repoRoot" merge "$branchName" 2>&1)
  mergeStatus=$?

  if (( mergeStatus )); then
    git -C "$repoRoot" merge --abort 2>/dev/null
    _gw_log error 'error: merge conflict; aborting'
    print -r -- "$mergeOutput"
    gwdiff "${worktreeDir:t}"
    return 1
  fi

  _gw_log success "Merged %F{yellow}${branchName}%f into %F{green}${targetBranch}%f"
  gwr "${worktreeDir:t}"
}
