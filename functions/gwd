# Remove a worktree and return to the nearest repo root if the current shell
# was somewhere inside .worktrees/.
#
# Blocks removal when the worktree has unmerged commits (use --force to
# override). If deletion fails for any reason, this prints the same structured
# diagnostic view exposed by "gwdiff" so the reason is immediately visible.
gwd() {
  local arg currentDir gitCommonDir hasForce=0 mainHead removeOutput repoRoot
  local shouldCdBack=0 unmergedOutput worktreeDir

  gitCommonDir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  repoRoot=${gitCommonDir:h}
  currentDir=${PWD:A}
  worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")

  for arg in "$@"; do [[ $arg == "--force" || $arg == "-f" ]] && hasForce=1; done

  [[ $currentDir == "$repoRoot/.worktrees" || $currentDir == "$repoRoot/.worktrees/"* ]] && shouldCdBack=1

  if (( ! hasForce )) && [[ -n "$worktreeDir" ]]; then
    mainHead=$(git -C "$repoRoot" rev-parse HEAD 2>/dev/null)
    [[ -n "$mainHead" ]] && unmergedOutput=$(git -C "$worktreeDir" log --oneline "$mainHead..HEAD" 2>/dev/null)
    if [[ -n "$unmergedOutput" ]]; then
      print "error: worktree has unmerged commits"
      _gw_print_worktree_diff "$worktreeDir"
      return 1
    fi
  fi

  local worktreeName=${worktreeDir:t} spinnerPid removeStatus
  _gw_spinner "Removing worktree \"$worktreeName\"" &
  spinnerPid=$!
  removeOutput=$(git worktree remove "$@" 2>&1)
  removeStatus=$?
  kill $spinnerPid 2>/dev/null
  wait $spinnerPid 2>/dev/null
  print -rn -- "\r\e[2K" >>/dev/tty

  if (( removeStatus )); then
    print -r -- "$removeOutput"
    [[ -n "$worktreeDir" ]] && _gw_print_worktree_diff "$worktreeDir"
    return 1
  fi

  (( shouldCdBack )) && gwp
}
