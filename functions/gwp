# Jump to the nearest repo root recognized by this helper suite.
#
# The marker is ".worktrees", not ".git". That distinction matters because we
# want "gwp" to land on the owning repository root even when the current shell
# is inside a linked worktree.
gwp() {
  local repoRoot
  repoRoot=$(_gw_find_repo_root) || {
    local common_dir
    common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
    repoRoot=${common_dir%/.git}
  }
  _gw_log success "Returned to repo root %F{yellow}${repoRoot:t}%f"
  builtin cd "$repoRoot"
}
