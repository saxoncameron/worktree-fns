# Show the current change summary for a named worktree on demand.
#
# This is useful both for ad hoc inspection and for explaining why a "gwr"
# deletion failed. Keeping it as a first-class command also makes the failure
# path in "gwr" much easier to reason about.
gwdiff() {
  local currentDir repoRoot worktreeDir worktreeName hasArg=0

  for arg in "$@"; do [[ $arg != -* ]] && { hasArg=1; break }; done

  repoRoot=$(_gw_find_repo_root) || return 1
  currentDir=${PWD:A}

  if (( !hasArg )); then
    if [[ $currentDir == "$repoRoot/.worktrees/"* ]]; then
      worktreeName=${currentDir#"$repoRoot/.worktrees/"}
      worktreeName=${worktreeName%%/*}
      worktreeDir="$repoRoot/.worktrees/$worktreeName"
    else
      _gw_log error 'Usage: gwdiff <worktree>' >&2
      gwls >&2
      return 1
    fi
  fi

  [[ -n "$worktreeDir" ]] || worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")

  [[ -n "$worktreeDir" ]] || {
    _gw_log error 'error: could not resolve worktree'
    gwls >&2
    return 1
  }

  _gw_log info "Inspecting worktree %F{yellow}${worktreeDir:t}%f"
  _gw_print_worktree_diff "$worktreeDir"
}
