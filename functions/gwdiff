# Show the current change summary for a named worktree on demand.
#
# This is useful both for ad hoc inspection and for explaining why a "gwd"
# deletion failed. Keeping it as a first-class command also makes the failure
# path in "gwd" much easier to reason about.
gwdiff() {
  local gitCommonDir repoRoot worktreeDir hasArg=0

  for arg in "$@"; do [[ $arg != -* ]] && { hasArg=1; break }; done

  if (( !hasArg )); then
    print -u2 "Usage: gwdiff <worktree>"
    gwls >&2
    return 1
  fi

  gitCommonDir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  repoRoot=${gitCommonDir:h}
  worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")

  [[ -n "$worktreeDir" ]] || return 1
  _gw_print_worktree_diff "$worktreeDir"
}
