# Lightweight wrapper so the worktree helper suite exposes a complete "gw*"
# surface without relying on aliases in ~/.zshrc.
#
# Captures porcelain output into a variable first, then parses with zsh
# builtins — avoids pipelines / process substitution into loops where
# autoloaded functions and PATH can behave unexpectedly.
gwls() {
  local repo_root listedWorktreePath worktreePath branch indicator short commits shortstat insertions deletions
  local -a entries worktreeDirs

  repo_root=$(_gw_find_repo_root) || {
    # Fall back to git's common dir when not under a .worktrees parent
    local common_dir
    common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
    repo_root=${common_dir%/.git}
    [[ -d "$repo_root/.worktrees" ]] || return 1
  }
  git -C "$repo_root" worktree prune >/dev/null 2>&1
  while IFS= read -r listedWorktreePath; do
    [[ -n "$listedWorktreePath" ]] && worktreeDirs+=("$listedWorktreePath")
  done <<< "$(_gw_worktree_dirs "$repo_root")"

  for worktreePath in "${worktreeDirs[@]}"; do
    branch=$(git -C "$worktreePath" symbolic-ref --quiet HEAD 2>/dev/null)
    indicator=""

    if [[ -n "$branch" && "$branch" != "refs/heads/main" ]]; then
      short=${branch##refs/heads/}
      commits=$(git -C "$repo_root" rev-list --count "main..$short" 2>/dev/null)

      if [[ "$commits" -gt 0 ]]; then
        shortstat=$(git -C "$repo_root" diff "main...$short" --shortstat 2>/dev/null)
        insertions=0
        deletions=0
        [[ "$shortstat" =~ '([0-9]+) insertion' ]] && insertions=$match[1]
        [[ "$shortstat" =~ '([0-9]+) deletion' ]] && deletions=$match[1]
        indicator=" %F{green}(+${insertions}/-${deletions} lines, ${commits} commits)%f"
      fi
    fi

    entries+=("  - %F{yellow}${worktreePath:t}%f$indicator")
  done

  print ""
  if (( ${#entries} == 0 )); then
    _gw_log info "No worktrees found. Use %F{cyan}gwa%f to add one."
  else
    _gw_log list 'Available worktrees:'
    for entry in "${entries[@]}"; do print -P "$entry"; done
  fi
}
