# Print the owning repo root recognized by this helper suite.
#
# This prefers the nearest ".worktrees" marker so linked worktrees resolve back
# to the managed repo root, then falls back to Git's common dir when needed.
_gw_repo_root_path() {
  local commonDir repoRoot
  repoRoot=$(_gw_find_repo_root) || {
    commonDir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
    repoRoot=${commonDir%/.git}
  }

  print -r -- "${repoRoot:A}"
}
