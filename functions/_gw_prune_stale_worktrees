# Remove stale Git metadata for missing linked worktrees.
#
# Git can keep prunable worktree records after the on-disk directory is gone.
# Pruning them keeps "gwls" aligned with the actual .worktrees directory.
_gw_prune_stale_worktrees() {
  local repoRoot
  repoRoot=$1

  [[ -n "$repoRoot" ]] || return 1
  git -C "$repoRoot" worktree prune >/dev/null 2>&1
}
