# Cd into a named worktree directory under the nearest repo's .worktrees dir.
#
# This intentionally accepts the short worktree name rather than requiring a
# full path, because the standardized ./.worktrees/<name> layout makes that
# unambiguous.
gwcd() {
  local worktreeDir
  worktreeDir=$(_gw_selected_worktree_path "$@") || return 1
  builtin cd "$worktreeDir"
}
