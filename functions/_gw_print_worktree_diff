# Print a compact, colorized diagnostic view of a worktree's changes.
#
# Shows, in order:
# - unstaged change summary (diff --stat)
# - unmerged commits (ahead of main worktree HEAD)
#
# This is shared by "gwr" and "gwdiff" so both commands explain the worktree in
# exactly the same way.
_gw_print_worktree_diff() {
  local gitCommonDir mainHead repoRoot unmergedOutput unstagedOutput worktreeDir
  worktreeDir=$1

  [[ -d "$worktreeDir" ]] || return 1

  gitCommonDir=$(git -C "$worktreeDir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
  repoRoot=${gitCommonDir:h}
  mainHead=$(git -C "$repoRoot" rev-parse HEAD 2>/dev/null)

  unstagedOutput=$(git -C "$worktreeDir" -c color.ui=always diff --stat --stat-graph-width=3 2>/dev/null)
  [[ -n "$mainHead" ]] && unmergedOutput=$(git -C "$worktreeDir" log --oneline "$mainHead..HEAD" 2>/dev/null)

  echo
  if [[ -z "$unstagedOutput" && -z "$unmergedOutput" ]]; then
    _gw_log success "Worktree has no pending changes: %F{yellow}${worktreeDir:t}%f"
    return 0
  fi
  _gw_log warn "Worktree has pending changes: %F{yellow}${worktreeDir:t}%f"

  if [[ -n "$unstagedOutput" ]]; then
    local summaryLine fileLines
    summaryLine=${unstagedOutput##*$'\n'}
    fileLines=${unstagedOutput%$'\n'*}
    echo
    _gw_log error 'Unstaged changes:'
    print -r -- "$summaryLine"
    print -r -- "$fileLines"
  fi

  if [[ -n "$unmergedOutput" ]]; then
    echo
    _gw_log info 'Unmerged commits:'
    print -r -- "$unmergedOutput"
  fi
}
