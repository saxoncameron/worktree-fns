# Create a linked worktree under ./.worktrees/<name> and cd into it.
#
# The helper deliberately standardizes the location of linked worktrees so the
# rest of the suite can reason about them consistently.
#
# After Git creates the worktree, we copy a small set of local overlay files
# into it. That preserves untracked .env files and nested .gitignore files that
# often matter in day-to-day development but are not part of the checkout.
gwa() {
  local worktreeRoot
  worktreeRoot=$(_gw_add_worktree "$@") || return 1
  builtin cd "$worktreeRoot"
}
