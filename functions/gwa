# Create a linked worktree under ./.worktrees/<name> and cd into it.
#
# The helper deliberately standardizes the location of linked worktrees so the
# rest of the suite can reason about them consistently.
#
# After Git creates the worktree, we copy a small set of local overlay files
# into it. That preserves untracked .env files and nested .gitignore files that
# often matter in day-to-day development but are not part of the checkout.
gwa() {
  [[ -n "$1" ]] || {
    _gw_log error 'Usage: gwa <name> [branch]'
    return 1
  }

  local repoRoot worktreeRoot
  repoRoot=$(_gw_find_repo_root) || repoRoot=$(git rev-parse --show-toplevel) || return 1
  worktreeRoot="$repoRoot/.worktrees/$1"

  _gw_log step "Creating worktree %F{yellow}${1}%f"

  if [[ -n "$2" ]]; then
    git -C "$repoRoot" worktree add "$worktreeRoot" "$2" || {
      _gw_log error "Failed to create worktree %F{yellow}${1}%f"
      return 1
    }
  else
    git -C "$repoRoot" worktree add "$worktreeRoot" || {
      _gw_log error "Failed to create worktree %F{yellow}${1}%f"
      return 1
    }
  fi

  _gw_copy_local_overlay_files "$repoRoot" "$worktreeRoot"
  _gw_log success "Created worktree %F{yellow}${1}%f"
  _gw_log info "Entered worktree %F{yellow}${1}%f"
  builtin cd "$worktreeRoot"
}
