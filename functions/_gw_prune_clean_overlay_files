# Remove untouched copied overlay files that would otherwise appear as local
# changes and block "git worktree remove".
#
# Only files that are:
# - present in both repo root and worktree
# - untracked in the worktree
# - byte-identical to the repo-root source
#
# are pruned. Any user-edited overlay or unrelated untracked file remains and
# continues to block destructive commands.
_gw_prune_clean_overlay_files() {
  local listedPath overlayRelPath repoRoot worktreeDir worktreePath
  repoRoot=$1
  worktreeDir=$2

  [[ -d "$repoRoot" && -d "$worktreeDir" ]] || return 1

  while IFS= read -r overlayRelPath; do
    [[ -n "$overlayRelPath" ]] || continue
    worktreePath="$worktreeDir/$overlayRelPath"

    [[ -f "$repoRoot/$overlayRelPath" && -f "$worktreePath" ]] || continue
    [[ -z "$(git -C "$worktreeDir" ls-files --error-unmatch -- "$overlayRelPath" 2>/dev/null)" ]] || continue
    listedPath=$(git -C "$worktreeDir" ls-files --others --exclude-standard -- "$overlayRelPath" 2>/dev/null)
    [[ "$listedPath" == "$overlayRelPath" ]] || continue
    cmp -s "$repoRoot/$overlayRelPath" "$worktreePath" || continue
    /bin/rm -f "$worktreePath"
  done <<< "$(_gw_overlay_relpaths "$repoRoot")"
}
