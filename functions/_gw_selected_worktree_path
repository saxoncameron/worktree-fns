# Resolve a user-supplied worktree selector and print the absolute directory.
_gw_selected_worktree_path() {
  local repoRoot worktreeDir

  [[ -n "$1" ]] || {
    print -u2 'Usage: gwcd <worktree>'
    return 1
  }

  repoRoot=$(_gw_repo_root_path) || return 1
  worktreeDir=$(_gw_resolve_worktree_dir "$repoRoot" "$@")

  [[ -n "$worktreeDir" ]] || return 1
  print -r -- "$worktreeDir"
}
