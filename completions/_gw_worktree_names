#compdef gwcd gwr gwrf gwdiff gwh gwm

# Complete worktree names from the nearest repo's .worktrees directory.
#
# Prefix matching and tab-cycling are handled natively by the zsh completion
# system — compadd supplies the candidate list and zsh narrows it to whatever
# the user has typed so far.
_gw_worktree_names() {
  local repoRoot gitCommonDir
  local -a names

  repoRoot=$(_gw_find_repo_root) || return 1
  [[ -d "$repoRoot/.worktrees" ]] || return 1

  local d
  for d in "$repoRoot"/.worktrees/*(/N); do
    gitCommonDir=$(unset GIT_DIR GIT_WORK_TREE; git -C "$d" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || continue
    [[ "$gitCommonDir" == "$repoRoot/.git" ]] || continue
    names+=("${d:t}")
  done

  (( ${#names} )) || return 1

  # Only complete the first non-flag argument — prevent appending extra names
  # after one has already been accepted.
  local w nonflag=0
  for w in "${words[@]:1:$((CURRENT-2))}"; do
    [[ $w != -* ]] && (( ++nonflag ))
  done
  (( nonflag )) && return 0

  _describe 'worktree' names
}
