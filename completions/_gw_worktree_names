#compdef gwcd gwd gwdf gwdiff gwh gwm

# Complete worktree names from the nearest repo's .worktrees directory.
#
# This completion function is shared by every command that expects a worktree
# identifier, which keeps the command files themselves focused on behavior.
_gw_worktree_names() {
  (( CURRENT > 2 )) && return 1

  local repoRoot worktreeDir
  local -a worktreeDirs worktreeNames

  repoRoot=$(_gw_find_repo_root) || return 1
  while IFS= read -r worktreeDir; do
    [[ -n "$worktreeDir" ]] && worktreeDirs+=("$worktreeDir")
  done <<< "$(_gw_worktree_dirs "$repoRoot")"
  worktreeNames=("${worktreeDirs:t}")

  (( ${#worktreeNames} )) || return 1
  local expl
  _wanted worktrees expl 'worktree' compadd -a worktreeNames
}
